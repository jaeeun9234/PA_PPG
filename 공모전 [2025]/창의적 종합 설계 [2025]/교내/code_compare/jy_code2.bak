/*
 * HeartSync Standalone (ESP32, Arduino IDE) - v1.4.2a
 * - Dual PPG: AmpRatio, PAD, ΔSUT + side inference(+balanced)
 * - PPGf_L / PPGf_R(DC 제거+이동평균) 포함
 * - ALERT 래칭: HOLD_ALERT / HOLD_CLEAR / GAP_TOL (잠깐 끊김 허용)
 * - 원인 기억 플래그(cause_amp/pad/dsut): reasons가 항상 구체 라벨로 출력
 * - 리마인드에도 FULL 필드 + dur_s(래칭 후 경과초) 포함
 * - BLE Notify & Serial(115200)
 *
 * [fix]
 *  - amplitudeInWindow(): 잘못된 중괄호/리턴 위치 수정 + NaN 방지
 *  - AmpRatio: 항상 계산(0-분모 방지, EPS 처리)로 보호 → ampL/ampR 다르면 1.00 고정 현상 방지
 *  - 출력 포맷/순서는 그대로 유지(파서 호환)
 *
 * 메모: 터미널 인코딩 이슈가 있으면 "ΔSUT" 라벨을 "dSUT"로 바꿔도 무방
 */

#include <Arduino.h>
#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEServer.h>
#include <BLE2902.h>

// ===== BLE UUID =====
#define SERVICE_UUID     "5ba7a52c-c3fe-46eb-8ade-0dacbd466278"
#define CHAR_STREAM_UUID "5dde726d-4cf3-4e2f-ab24-323caa359b78"

BLEServer*         g_server   = nullptr;
BLEService*        g_service  = nullptr;
BLECharacteristic* g_stream   = nullptr;
bool g_centralConnected = false;

class ServerCallbacks : public BLEServerCallbacks {
  void onConnect(BLEServer* pServer) override { g_centralConnected = true; }
  void onDisconnect(BLEServer* pServer) override {
    g_centralConnected = false;
    BLEDevice::startAdvertising();
  }
};

// ===== Pins / Sampling =====
const int PIN_L = 34;                 // Left PPG (ADC)
const int PIN_R = 35;                 // Right PPG (ADC)

const int FS_HZ   = 100;              // ADC sampling rate (Hz)
const int delayMs = 1000 / FS_HZ;     // loop pacing

// ===== Windows / Thresholds =====
const int DC_WIN      = 20;           // DC removal (moving average)
const int SMOOTH_WIN  = 5;            // smoothing window
const int AMP_WIN_SEC = 2;            // amplitude window (seconds)
const int AMP_WIN     = AMP_WIN_SEC * FS_HZ;

// Feature thresholds
float   AMP_RATIO_THR = 0.70f;
int     PAD_THR_MS    = 25;
int     DSUT_THR_MS   = 150;
uint8_t PQI_MIN       = 40;

// ALERT timing
const uint32_t HOLD_ALERT_MS    = 60000;  // 비대칭 조건 연속 유지 → ALERT 래칭
const uint32_t HOLD_CLEAR_MS    = 15000;  // 정상 조건 연속 유지 → ALERT 해제
const uint32_t GAP_TOL_MS       = 3000;   // 잠깐 끊김 허용(누적 유지)
const uint32_t STAT_INTERVAL_MS = 100;    // STAT 전송 간격
const uint32_t ALERT_REPEAT_MS  = 30000;  // 래칭 중 리마인드 주기(0=끄기)

// ===== Sensor struct =====
struct PPGSensor {
  int pin;
  int   dcBuf[DC_WIN];     
  int   dcIdx = 0;
  float smoothBuf[SMOOTH_WIN]; 
  int smoothIdx = 0;
  float waveBuf[AMP_WIN];  
  int   waveIdx = 0; 
  bool  waveFilled = false;
  float peakBuf[10];       
  int   peakIdx = 0;
  bool  isPeak = false;
  unsigned long lastPeakTime = 0;
  unsigned long overThStart  = 0; 
  float bpm = 0;
  float lastSmoothed = 0;
  int   lastRaw = 0;

  // foot/SUT 추정
  unsigned long lastFoot = 0;
  unsigned long lastSUT  = 0;
  float lastVal = 0;
  bool  inUp = false;
  float minVal = 1e9;
  unsigned long minAt = 0;
};

PPGSensor L, R;

// ===== Utils =====
uint8_t calcPQI(float smoothed, int raw) {
  // 간단 휴리스틱: 클리핑/저진폭 벌점 → 100에서 감점
  int clip = (raw < 50 || raw > 4045) ? 40 : 0;
  int low  = (fabsf(smoothed) < 3.0f) ? 30 : 0;
  int score = 100 - (clip + low);
  if (score < 0) score = 0; if (score > 100) score = 100;
  return (uint8_t)score;
}

float movAvg(float* buf, int win) { float s=0; for(int i=0;i<win;i++) s+=buf[i]; return s/(float)win; }

float processOne(PPGSensor &S, int raw) {
  S.lastRaw = raw;
  // DC removal
  S.dcBuf[S.dcIdx] = raw; S.dcIdx = (S.dcIdx + 1) % DC_WIN;
  int sum = 0; for (int i=0;i<DC_WIN;i++) sum += S.dcBuf[i];
  float mean = sum / (float)DC_WIN;
  float ac = raw - mean;
  // smoothing
  S.smoothBuf[S.smoothIdx] = ac; S.smoothIdx = (S.smoothIdx + 1) % SMOOTH_WIN;
  float sm = movAvg(S.smoothBuf, SMOOTH_WIN);
  S.lastSmoothed = sm;
  // ring buffer for amplitude
  S.waveBuf[S.waveIdx] = sm; S.waveIdx = (S.waveIdx + 1) % AMP_WIN;
  if (S.waveIdx == 0) S.waveFilled = true;
  return sm;
}

bool detectPeak(PPGSensor &S, float sm, unsigned long now) {
  const int minInterval = 333; 
  const int holdMs = 30;
  // dynamic threshold
  S.peakBuf[S.peakIdx] = sm; S.peakIdx = (S.peakIdx + 1) % 10;
  float ps=0; for(int i=0;i<10;i++) ps += S.peakBuf[i];
  float dynTh = ps/10.0f + 60.0f; // offset=60 (튜닝 지점)

  if (!S.isPeak) {
    if (sm > dynTh) {
      if (S.overThStart == 0) S.overThStart = now;
      if ((now - S.overThStart) > (unsigned)holdMs && (now - S.lastPeakTime) > (unsigned)minInterval) {
        S.isPeak = true;
        if (S.lastPeakTime > 0) {
          float ibi = (now - S.lastPeakTime) / 1000.0f;
          float bpmNow = (ibi > 0) ? (60.0f / ibi) : 0;
          if (bpmNow > 30 && bpmNow < 180) S.bpm = 0.6f*S.bpm + 0.4f*bpmNow; // EMA
        }
        S.lastPeakTime = now;
        return true;
      }
    } else {
      S.overThStart = 0;
    }
  } else if (sm < dynTh) {
    S.isPeak = false;
    S.overThStart = 0;
  }
  return false;
}

bool updateFoot(PPGSensor &S, float x, unsigned long now) {
  bool foot = false;
  if (x < S.minVal) { S.minVal = x; S.minAt = now; }
  bool up = (x > S.lastVal);
  if (!S.inUp && up) {
    S.lastFoot = now; foot = true;
    S.minVal = 1e9; S.minAt = now;
  }
  S.inUp = up; S.lastVal = x;
  return foot;
}

// === FIXED: amplitudeInWindow (중괄호/NaN 보정) ===
float amplitudeInWindow(const PPGSensor &S) {
  int N = S.waveFilled ? AMP_WIN : S.waveIdx;
  if (N < 8) return 0.0f;

  float mn = 1e9f, mx = -1e9f;
  for (int i = 0; i < N; i++) {
    float v = S.waveBuf[i];
    if (v < mn) mn = v;
    if (v > mx) mx = v;
  }
  float amp = mx - mn;
  // NaN/음수 방지
  if (!(amp >= 0.0f)) amp = 0.0f;
  return (amp > 0.0f) ? amp : 0.0f;
}

// ===== I/O helpers =====
void sendLine(const String &msg) {
  Serial.println(msg);                 // UART는 println이어서 개행 O
  if (g_centralConnected) {
    String wire = msg + "\n";          // BLE notify에 개행 포함
    g_stream->setValue((uint8_t*)wire.c_str(), wire.length());
    g_stream->notify();
  }
}

// ===== Global state =====
unsigned long lastStatSent = 0;

// v1.4.x alert latching
static bool inViolation = false;     // 임계 초과 상태 중
static bool alerting    = false;     // ALERT 래칭
static unsigned long violStart = 0;  // 초과 시작 시각
static unsigned long lastMeet  = 0;  // 마지막 초과 확인 시각
static unsigned long clearStart= 0;  // 정상 시작 시각
static unsigned long lastAlertAt = 0;// 리마인드 타이머
static unsigned long latchAt = 0;    // 래칭 시작 시각 (dur_s)

// 원인 기억 플래그(에피소드 동안 유지)
static bool cause_amp=false, cause_pad=false, cause_dsut=false;

// ===== Setup =====
void setup() {
  Serial.begin(115200);
  delay(1000); // USB CDC 안정화(ESP32-S2/S3면 필수)

  memset(&L, 0, sizeof(L)); L.pin = PIN_L;
  memset(&R, 0, sizeof(R)); R.pin = PIN_R;
  for (int i=0;i<DC_WIN;i++){ L.dcBuf[i]=0; R.dcBuf[i]=0; }
  for (int i=0;i<SMOOTH_WIN;i++){ L.smoothBuf[i]=0; R.smoothBuf[i]=0; }
  for (int i=0;i<10;i++){ L.peakBuf[i]=0; R.peakBuf[i]=0; }

  // BLE
  BLEDevice::init("HeartSync");
  g_server = BLEDevice::createServer();
  g_server->setCallbacks(new ServerCallbacks());
  g_service = g_server->createService(SERVICE_UUID);
  g_stream  = g_service->createCharacteristic(CHAR_STREAM_UUID, BLECharacteristic::PROPERTY_NOTIFY);
  g_stream->addDescriptor(new BLE2902());
  g_service->start();

  BLEAdvertising* adv = BLEDevice::getAdvertising();
  BLEAdvertisementData advData; advData.setName("HeartSync"); advData.setCompleteServices(BLEUUID(SERVICE_UUID));
  adv->setAdvertisementData(advData);
  BLEAdvertisementData scanData; scanData.setName("HeartSync"); adv->setScanResponseData(scanData);
  adv->setScanResponse(true);
  BLEDevice::startAdvertising();
}

// ===== Main Loop =====
void loop() {
  unsigned long now = millis();

  // 1) Read + preprocess
  int rawL = analogRead(L.pin);
  int rawR = analogRead(R.pin);

  float smL = processOne(L, rawL);
  float smR = processOne(R, rawR);

  bool peakL = detectPeak(L, smL, now);
  bool peakR = detectPeak(R, smR, now);

  bool footL = updateFoot(L, smL, now);
  bool footR = updateFoot(R, smR, now);

  if (peakL && L.lastFoot > 0 && L.lastFoot <= L.lastPeakTime) L.lastSUT = L.lastPeakTime - L.lastFoot;
  if (peakR && R.lastFoot > 0 && R.lastFoot <= R.lastPeakTime) R.lastSUT = R.lastPeakTime - R.lastFoot;

  // 2) Features
  long PAD_ms = 0;
  if (L.lastFoot > 0 && R.lastFoot > 0) PAD_ms = (long)R.lastFoot - (long)L.lastFoot;

  uint8_t pqiL = calcPQI(smL, L.lastRaw);
  uint8_t pqiR = calcPQI(smR, R.lastRaw);
  bool pqiOK = (pqiL >= PQI_MIN) && (pqiR >= PQI_MIN);

  float ampL = amplitudeInWindow(L);
  float ampR = amplitudeInWindow(R);

  // === FIXED: AmpRatio 계산 (항상 0~1, 0-분모 보호, EPS 처리) ===
  float ampRatio;
  const float EPS = 1e-6f;
  if (ampL <= EPS && ampR <= EPS) {
    ampRatio = 1.0f;                     // 둘 다 사실상 0 → 의미 없으니 1로
  } else if (ampL >= ampR && ampL > EPS) {
    ampRatio = ampR / ampL;              // 항상 0~1 사이
  } else if (ampR > EPS) {
    ampRatio = ampL / ampR;
  } else {
    ampRatio = 1.0f;                     // 안전장치
  }

  long dSUT = (long)R.lastSUT - (long)L.lastSUT;

  // 3) Side inference (+balanced)
  const float AMP_SIDE_FACTOR = 0.8f;
  int scoreL = 0, scoreR = 0;
  if (ampR <= AMP_SIDE_FACTOR * ampL) scoreR++;
  if (ampL <= AMP_SIDE_FACTOR * ampR) scoreL++;
  if (PAD_ms >= PAD_THR_MS) scoreR++; else if (PAD_ms <= -PAD_THR_MS) scoreL++;
  if (dSUT   >= DSUT_THR_MS) scoreR++; else if (dSUT   <= -DSUT_THR_MS) scoreL++;

  bool balanced = pqiOK &&
                  (ampRatio > AMP_RATIO_THR) &&
                  (abs(PAD_ms) < PAD_THR_MS) &&
                  (abs(dSUT)   < DSUT_THR_MS);

  const char* side = "uncertain";
  if (balanced) {
    side = "balanced";
  } else if (pqiOK) {
    if (scoreR >= 2) side = "right";
    else if (scoreL >= 2) side = "left";
  }

  // 4) ALERT latching + cause flags
  bool asymNow = pqiOK && (
    (ampRatio <= AMP_RATIO_THR) ||
    (abs(PAD_ms) >= PAD_THR_MS) ||
    (abs(dSUT)   >= DSUT_THR_MS)
  );

  if (asymNow) {
    if (!inViolation) { inViolation = true; violStart = now; }
    lastMeet = now;
    // 누적에 기여한 원인 기록(에피소드 지속)
    cause_amp  |= (ampRatio <= AMP_RATIO_THR);
    cause_pad  |= (abs(PAD_ms) >= PAD_THR_MS);
    cause_dsut |= (abs(dSUT)   >= DSUT_THR_MS);
  } else {
    // 잠깐 끊김은 허용(GAP_TOL 이내면 유지)
    if (inViolation && (now - lastMeet) > GAP_TOL_MS) {
      inViolation = false;
      // 에피소드 전에 누적이 끊겼으면 원인도 리셋
      cause_amp = cause_pad = cause_dsut = false;
    }
  }

  auto makeReasons = [&]()->String {
    String r="";
    if (cause_amp)  r += (r.length()? ", ":"") + String("AmpRatio low");
    if (cause_pad)  r += (r.length()? ", ":"") + String("PAD high");
    if (cause_dsut) r += (r.length()? ", ":"") + String("ΔSUT high");
    if (r.length()==0) r = "sustained asymmetry";
    return r;
  };

  // 래칭 진입
  if (!alerting && inViolation && (now - violStart) >= HOLD_ALERT_MS) {
    alerting = true;
    latchAt = now;

    String reasons_now = makeReasons();
    unsigned long dur_s = 0;

    char msg[460];
    snprintf(msg, sizeof(msg),
      "ALERT ts=%lu side=%s type=%s reasons=%s dur_s=%lu "
      "AmpRatio=%.2f PAD=%ld dSUT=%ld "
      "PPGf_L=%.2f PPGf_R=%.2f ampL=%.1f ampR=%.1f "
      "SUTL=%lu SUTR=%lu BPM_L=%.1f BPM_R=%.1f PQIL=%u PQIR=%u",
      now, side, "asymmetry", reasons_now.c_str(), dur_s,
      ampRatio, PAD_ms, dSUT,
      smL, smR, ampL, ampR,
      L.lastSUT, R.lastSUT, L.bpm, R.bpm, pqiL, pqiR
    );
    sendLine(String(msg));
    lastAlertAt = now;
  }

  // 래칭 중 상태 유지/해제/리마인드
  if (alerting) {
    bool backToNormal = pqiOK && (ampRatio > AMP_RATIO_THR) &&
                        (abs(PAD_ms) < PAD_THR_MS) && (abs(dSUT) < DSUT_THR_MS);

    if (backToNormal) {
      if (clearStart == 0) clearStart = now;
      if ((now - clearStart) >= HOLD_CLEAR_MS) {
        alerting = false;
        clearStart = 0;
        cause_amp = cause_pad = cause_dsut = false; // 에피소드 종료 → 원인 리셋
      }
    } else {
      clearStart = 0;

      if (ALERT_REPEAT_MS > 0 && (now - lastAlertAt) >= ALERT_REPEAT_MS) {
        String reasons_now = makeReasons();
        unsigned long dur_s = (latchAt>0)? (now - latchAt)/1000UL : 0;

        char msg2[460];
        snprintf(msg2, sizeof(msg2),
          "ALERT ts=%lu side=%s type=%s reasons=%s;ongoing dur_s=%lu "
          "AmpRatio=%.2f PAD=%ld dSUT=%ld "
          "PPGf_L=%.2f PPGf_R=%.2f ampL=%.1f ampR=%.1f "
          "SUTL=%lu SUTR=%lu BPM_L=%.1f BPM_R=%.1f PQIL=%u PQIR=%u",
          now, side, "asymmetry", reasons_now.c_str(), dur_s,
          ampRatio, PAD_ms, dSUT,
          smL, smR, ampL, ampR,
          L.lastSUT, R.lastSUT, L.bpm, R.bpm, pqiL, pqiR
        );
        sendLine(String(msg2));
        lastAlertAt = now;
      }
    }
  }

  // 5) STAT 출력
  if (now - lastStatSent >= STAT_INTERVAL_MS) {
    lastStatSent = now;
    char stat[460];
    snprintf(stat, sizeof(stat),
      "STAT ts=%lu side=%s AmpRatio=%.2f PAD=%ld dSUT=%ld "
      "PPGf_L=%.2f PPGf_R=%.2f ampL=%.1f ampR=%.1f SUTL=%lu SUTR=%lu BPM_L=%.1f BPM_R=%.1f PQIL=%u PQIR=%u",
      now, side, ampRatio, PAD_ms, dSUT,
      smL, smR, ampL, ampR, L.lastSUT, R.lastSUT, L.bpm, R.bpm, pqiL, pqiR
    );
    sendLine(String(stat));
  }

  // 6) pacing
  delay(delayMs);
}
